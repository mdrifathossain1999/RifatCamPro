<Window x:Class="RifatCamPro.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RifatCamPro.Client.ViewModels"
        xmlns:models="clr-namespace:RifatCamPro.Client.Models"
        xmlns:local="clr-namespace:RifatCamPro.Client"
        Title="{Binding WindowTitle}"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        Background="{StaticResource SecondaryBackgroundBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>
        <local:NullToImageSourceConverter x:Key="NullToImgSrc"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="{StaticResource SecondaryBackgroundBrush}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="_Connect" Command="{Binding ConnectCommand}" InputGestureText="Ctrl+Enter"/>
                <MenuItem Header="_Disconnect" Command="{Binding DisconnectCommand}" InputGestureText="Ctrl+D"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Start _Virtual Camera" Command="{Binding ToggleVirtualCameraCommand}"/>
                <Separator/>
                <MenuItem Header="Scan for _Devices" Command="{Binding ScanCommand}" InputGestureText="F5"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About RifatCam Pro" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Device Discovery -->
            <Border Grid.Column="0" Background="{StaticResource SecondaryBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="12,12,12,8">
                        <TextBlock Text="Devices" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                        <Button Command="{Binding ScanCommand}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Stretch" Padding="8,6">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Scan for Devices"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                    <Setter Property="Text" Value="Scanning..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ListBox Grid.Row="1" Margin="8,0"
                             ItemsSource="{Binding DiscoveredDevices}"
                             SelectedItem="{Binding SelectedDevice}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="brd" Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="brd" Property="Background"
                                                            Value="{StaticResource TertiaryBackgroundBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="brd" Property="Background"
                                                            Value="{StaticResource PrimaryAccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,2">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Text="{Binding Endpoint}" FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                    <Border Grid.Row="2" Margin="8,8" Padding="10"
                            Background="{StaticResource TertiaryBackgroundBrush}"
                            CornerRadius="6"
                            Visibility="{Binding SelectedDevice, Converter={StaticResource NullToVis}}">
                        <StackPanel>
                            <TextBlock Text="Device Info" FontWeight="SemiBold" Margin="0,0,0,6"
                                       Foreground="{StaticResource PrimaryAccentBrush}"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource SecondaryTextBrush}">
                                <Run Text="Name: " FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                <Run Text="{Binding SelectedDevice.DisplayName, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="{StaticResource SecondaryTextBrush}">
                                <Run Text="Address: " FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                <Run Text="{Binding SelectedDevice.Endpoint, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="{StaticResource SecondaryTextBrush}">
                                <Run Text="Model: " FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                <Run Text="{Binding SelectedDevice.Model, Mode=OneWay}"/>
                            </TextBlock>
                            <Button Content="Connect to Device" Margin="0,8,0,0"
                                    Command="{Binding ConnectCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="8,4,8,12">
                        <Button Command="{Binding ToggleTorchCommand}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Stretch" Margin="0,2" Padding="8,6">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Toggle Torch"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TorchEnabled}" Value="True">
                                                <Setter Property="Text" Value="Torch ON"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button Content="Switch Camera"
                                Command="{Binding SwitchCameraCommand}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Stretch" Margin="0,2" Padding="8,6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Center: Video Preview -->
            <Border Grid.Column="1" Background="#000000">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="#0A0A0A">
                        <Image Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding VideoFrame}"/>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    IsHitTestVisible="False">
                            <TextBlock Text="📷" FontSize="48" HorizontalAlignment="Center"
                                       Foreground="{StaticResource DisabledTextBrush}"/>
                            <TextBlock Text="No Signal" FontSize="20" FontWeight="Light"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"
                                       Foreground="{StaticResource DisabledTextBrush}"/>
                            <TextBlock FontSize="13" HorizontalAlignment="Center" Margin="0,4,0,0"
                                       Foreground="{StaticResource DisabledTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Connect to an iPhone to start streaming"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Connecting">
                                                <Setter Property="Text" Value="Connecting to device..."/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Authenticating">
                                                <Setter Property="Text" Value="Authenticating..."/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Streaming">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="12" Padding="8,6" CornerRadius="4"
                                Background="#AA000000">
                            <StackPanel>
                                <TextBlock Text="{Binding FpsText}" FontWeight="SemiBold"
                                           Foreground="{StaticResource SuccessGreenBrush}" FontSize="12"/>
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}">
                                    <Run Text="{Binding Stats.Width, Mode=OneWay, StringFormat='{}{0}x'}"
                                         Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <Run Text="{Binding Stats.Height, Mode=OneWay}"
                                         Foreground="{StaticResource SecondaryTextBrush}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="12" Padding="8,6" CornerRadius="4"
                                Background="#AA000000"
                                Visibility="{Binding IsVirtualCameraRunning, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource ErrorBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="VIRTUAL CAMERA ACTIVE" FontWeight="Bold"
                                           Foreground="{StaticResource ErrorBrush}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource SecondaryBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Padding="14,6" FontWeight="SemiBold"
                                    Command="{Binding ConnectCommand}"
                                    Style="{StaticResource SuccessButton}">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SecondaryBackgroundColorBrush}"/>
                                            <Setter Property="Text" Value="Connect"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Streaming">
                                                    <Setter Property="Text" Value="Disconnect"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Connected">
                                                    <Setter Property="Text" Value="Disconnect"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Connecting">
                                                    <Setter Property="Text" Value="Cancel"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>

                            <Button Grid.Column="2" Content="{Binding VirtualCameraButtonText}"
                                    Padding="14,6" Margin="8,0"
                                    Command="{Binding ToggleVirtualCameraCommand}"
                                    Style="{StaticResource PrimaryButton}"/>

                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding BitrateText}" Margin="12,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding LatencyText}" Margin="12,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Panel: Settings -->
            <Border Grid.Column="2" Background="{StaticResource SecondaryBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,12,12,16">

                        <TextBlock Text="Connection" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,10"/>

                        <TextBlock Text="Host / IP Address" Margin="0,0,0,4"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBox Text="{Binding HostAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Port" Margin="0,0,0,4"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Password (optional)" Margin="0,0,0,4"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10" Height="28"
                                     Background="{StaticResource TertiaryBackgroundBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" Padding="6,4"/>

                        <TextBlock Text="Protocol" Margin="0,0,0,4"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <ComboBox SelectedIndex="{Binding SelectedProtocolIndex}" Margin="0,0,0,10">
                            <ComboBoxItem Content="MJPEG"/>
                            <ComboBoxItem Content="H.264"/>
                        </ComboBox>

                        <TextBlock Text="Resolution" Margin="0,0,0,4"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding AvailableResolutions}"
                                  SelectedIndex="{Binding SelectedResolutionIndex}" Margin="0,0,0,10"/>

                        <TextBlock Text="Target FPS" Margin="0,0,0,4"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding AvailableFps}"
                                  SelectedIndex="{Binding SelectedFpsIndex}" Margin="0,0,0,10"/>

                        <CheckBox Content="Auto-reconnect"
                                  IsChecked="{Binding AutoReconnect}"
                                  Margin="0,4,0,12"/>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,4"/>

                        <TextBlock Text="Stream Statistics" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Margin="0,12,0,10"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FPS" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding FpsText}"
                                       Foreground="{StaticResource SuccessGreenBrush}" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bitrate" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding BitrateText}"
                                       Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Latency" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding LatencyText}"
                                       Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Frames" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Stats.FramesReceived}"
                                       Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Total Data" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold"
                                       Text="{Binding Stats.TotalBytesReceived, StringFormat='{}{0:N0} bytes'}"/>
                        </Grid>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,8"/>

                        <TextBlock Text="Virtual Camera" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Margin="0,12,0,10"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Status" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource DisabledTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVirtualCameraRunning}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource SuccessGreenBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Stopped"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVirtualCameraRunning}" Value="True">
                                                    <Setter Property="Text" Value="Running"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Compatible with: OBS, Zoom, Teams, Discord, Google Meet"
                                   TextWrapping="Wrap" FontSize="11" Margin="0,8,0,0"
                                   Foreground="{StaticResource DisabledTextBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource SecondaryBackgroundColorBrush}"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                   Padding="8,2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource DisabledTextBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Streaming">
                                        <Setter Property="Fill" Value="{StaticResource SuccessGreenBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Connected">
                                        <Setter Property="Fill" Value="{StaticResource PrimaryAccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                        <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Connecting">
                                        <Setter Property="Fill" Value="{StaticResource WarningBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatusText}" Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding FpsText}" Foreground="{StaticResource SecondaryTextBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding BitrateText}" Foreground="{StaticResource SecondaryTextBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding LatencyText}" Foreground="{StaticResource SecondaryTextBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
